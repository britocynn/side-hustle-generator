<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Side Hustle Generator</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background:
        radial-gradient(circle at top, #3c2b16 0%, #1b1712 22%, #121212 58%, #0f0f0f 100%);
      color: #f5ead9;
      text-align: center;
      padding: 36px 18px 60px;
      min-height: 100vh;
    }

    .container {
      max-width: 780px;
      margin: 0 auto;
      background: linear-gradient(180deg, #f8f0e3 0%, #efdfc5 100%);
      color: #2b241c;
      padding: 32px 22px 30px;
      border-radius: 24px;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(214, 178, 104, 0.35);
    }

    .title-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .logo-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg, #e0bb73, #9f6924);
      color: #fff8ee;
      font-size: 20px;
      box-shadow: 0 8px 18px rgba(156, 108, 40, 0.28);
    }

    h1 {
      margin: 0;
      font-size: 2.2rem;
      line-height: 1.15;
      color: #241d17;
      letter-spacing: -0.5px;
    }

    p#subtitle {
      margin: 10px 0 26px;
      color: #5d5042;
      font-size: 1.05rem;
    }

    .field-label {
      text-align: left;
      display: block;
      font-weight: 700;
      margin: 16px 0 8px;
      color: #3d3125;
      font-size: 0.95rem;
    }

    select,
    input {
      width: 100%;
      padding: 14px 16px;
      margin: 0;
      border-radius: 14px;
      border: 1px solid #d7c3a1;
      font-size: 16px;
      outline: none;
      background: #fffaf2;
      color: #2b241c;
      transition: all 0.2s ease;
      box-shadow: inset 0 1px 2px rgba(0,0,0,0.03);
    }

    select:focus,
    input:focus {
      border-color: #b88234;
      box-shadow: 0 0 0 4px rgba(184, 130, 52, 0.14);
    }

    .btn-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 22px;
    }

    button {
      border: none;
      padding: 14px 22px;
      border-radius: 14px;
      cursor: pointer;
      font-size: 16px;
      font-weight: 700;
      transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.2s ease;
    }

    button:hover {
      transform: translateY(-1px);
    }

    button:active {
      transform: translateY(0);
    }

    #generateBtn,
    #moreBtn {
      background: linear-gradient(135deg, #d6a84f, #9c6a26);
      color: #fff9f0;
      box-shadow: 0 10px 20px rgba(156, 106, 38, 0.22);
    }

    #copyBtn {
      background: #2d241b;
      color: #f7ead2;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.14);
    }

    #copyBtn,
    #moreBtn {
      display: none;
    }

    .result {
      margin-top: 28px;
      text-align: left;
      background: #fffaf4;
      padding: 20px;
      border-radius: 18px;
      border: 1px solid #ead6b4;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.55);
      display: none;
    }

    .result-title {
      margin: 0 0 16px;
      color: #8b5e1b;
      font-size: 1.15rem;
      font-weight: 700;
    }

    .idea {
      margin-bottom: 16px;
      padding: 16px 16px 18px;
      border-radius: 14px;
      background: linear-gradient(180deg, #fffdf9 0%, #f8f0e3 100%);
      border: 1px solid #eddcbc;
      line-height: 1.55;
    }

    .idea:last-child {
      margin-bottom: 0;
    }

    .idea-name {
      display: block;
      color: #2e241a;
      font-size: 1.05rem;
      margin-bottom: 10px;
    }

    .idea-desc {
      display: block;
      color: #4b3c2e;
      margin-bottom: 10px;
    }

    .idea-why {
      display: block;
      color: #7a5b34;
      font-style: italic;
    }

    .footer-note {
      margin-top: 26px;
      color: #6b5c49;
      font-size: 0.92rem;
    }

    @media (max-width: 640px) {
      body {
        padding: 20px 12px 40px;
      }

      .container {
        padding: 24px 16px 22px;
        border-radius: 20px;
      }

      h1 {
        font-size: 1.8rem;
      }

      .logo-icon {
        width: 36px;
        height: 36px;
        font-size: 17px;
      }

      .btn-row {
        flex-direction: column;
      }

      #generateBtn,
      #copyBtn,
      #moreBtn {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="title-wrap">
      <span class="logo-icon">✦</span>
      <h1 id="title">Side Hustle Generator</h1>
      <span class="logo-icon">✦</span>
    </div>

    <p id="subtitle">Generate side hustle ideas in seconds</p>

    <label class="field-label" id="languageLabel" for="language">Language</label>
    <select id="language" onchange="updateLanguage()">
      <option value="en">English</option>
      <option value="pt">Português</option>
    </select>

    <label class="field-label" id="interestLabel" for="interest">Skill, interest or niche</label>
    <input id="interest" placeholder="E.g. accounting, beauty, fitness, design" />

    <div class="btn-row">
      <button id="generateBtn" onclick="generateIdeas()">Generate Side Hustles</button>
      <button id="moreBtn" onclick="generateMoreIdeas()">Generate More Ideas</button>
      <button id="copyBtn" onclick="copyIdeas()">Copy Ideas</button>
    </div>

    <div id="result" class="result"></div>

    <div class="footer-note" id="footerNote">Smart tools for modern entrepreneurs</div>
  </div>

  <script>
    let currentInterest = "";
    let currentLanguage = "en";
    let currentSetIndex = 0;

    const ideaSetsEn = [
      [
        {
          name: "{interest} Freelance Service",
          desc: "Offer freelance help to individuals or small businesses using your knowledge in {interest}.",
          why: "Service-based side hustles are fast to start and require low investment."
        },
        {
          name: "{interest} Digital Templates",
          desc: "Sell digital templates, trackers, planners or worksheets related to {interest}.",
          why: "Digital products can be sold repeatedly with little ongoing effort."
        },
        {
          name: "{interest} Mini Coaching",
          desc: "Offer short paid sessions helping beginners improve in {interest}.",
          why: "People pay for clarity, speed and personalized advice."
        },
        {
          name: "{interest} Content Page",
          desc: "Create social media content around {interest} and monetize with products, services or partnerships.",
          why: "A focused audience can become a profitable niche brand."
        },
        {
          name: "{interest} Starter Guide",
          desc: "Create and sell a beginner-friendly ebook or guide about {interest}.",
          why: "Simple guides are easy to create and solve clear problems."
        }
      ],
      [
        {
          name: "{interest} Workshop Sessions",
          desc: "Host paid online workshops teaching practical skills related to {interest}.",
          why: "Live teaching creates trust and has strong perceived value."
        },
        {
          name: "{interest} Subscription Club",
          desc: "Build a small monthly membership with resources, tips and exclusive content about {interest}.",
          why: "Recurring income makes side hustles more stable."
        },
        {
          name: "{interest} Audit Service",
          desc: "Review a client’s current setup and suggest improvements related to {interest}.",
          why: "Many people will pay to know what they are doing wrong."
        },
        {
          name: "{interest} Resource Library",
          desc: "Curate a paid collection of tools, links, templates and recommendations around {interest}.",
          why: "Curated information saves time and feels high value."
        },
        {
          name: "{interest} Email Newsletter",
          desc: "Start a niche newsletter and monetize it through recommendations, products or premium access.",
          why: "Email audiences are valuable and easier to monetize over time."
        }
      ],
      [
        {
          name: "{interest} Done-for-You Package",
          desc: "Create a simple fixed-price offer where you do a specific task for clients related to {interest}.",
          why: "Clear offers are easier to sell than vague services."
        },
        {
          name: "{interest} Social Media Microbrand",
          desc: "Build a small personal brand around {interest} and use it to attract clients or sell digital products.",
          why: "Small audiences can still generate strong income if they trust you."
        },
        {
          name: "{interest} Toolkit Bundle",
          desc: "Package templates, scripts, checklists and mini guides into one paid bundle.",
          why: "Bundles increase perceived value and are easy to market."
        },
        {
          name: "{interest} One-to-One Support",
          desc: "Offer direct support sessions for people who need help getting started in {interest}.",
          why: "Personal support can command higher pricing."
        },
        {
          name: "{interest} Challenge Program",
          desc: "Create a 5-day or 7-day challenge helping people get a quick result in {interest}.",
          why: "Short programs are attractive because they feel achievable."
        }
      ]
    ];

    const ideaSetsPt = [
      [
        {
          name: "Serviço Freelancer de {interest}",
          desc: "Oferecer ajuda freelancer a pessoas ou pequenos negócios usando o teu conhecimento em {interest}.",
          why: "Serviços são rápidos de começar e exigem baixo investimento."
        },
        {
          name: "Templates Digitais de {interest}",
          desc: "Vender templates, trackers, planners ou folhas de trabalho relacionados com {interest}.",
          why: "Produtos digitais podem ser vendidos repetidamente com pouco esforço adicional."
        },
        {
          name: "Mini Sessões de Acompanhamento em {interest}",
          desc: "Oferecer sessões curtas pagas para ajudar iniciantes a melhorar em {interest}.",
          why: "As pessoas pagam por clareza, rapidez e orientação personalizada."
        },
        {
          name: "Página de Conteúdo sobre {interest}",
          desc: "Criar conteúdo nas redes sociais sobre {interest} e monetizar com produtos, serviços ou parcerias.",
          why: "Uma audiência focada pode transformar-se numa marca de nicho lucrativa."
        },
        {
          name: "Guia Inicial de {interest}",
          desc: "Criar e vender um ebook ou guia simples para iniciantes em {interest}.",
          why: "Guias simples são fáceis de criar e resolvem problemas claros."
        }
      ],
      [
        {
          name: "Workshops de {interest}",
          desc: "Criar workshops online pagos para ensinar competências práticas relacionadas com {interest}.",
          why: "Ensino ao vivo gera confiança e tem forte perceção de valor."
        },
        {
          name: "Clube por Subscrição de {interest}",
          desc: "Criar uma pequena subscrição mensal com recursos, dicas e conteúdo exclusivo sobre {interest}.",
          why: "Receita recorrente torna o side hustle mais estável."
        },
        {
          name: "Serviço de Auditoria em {interest}",
          desc: "Analisar a situação atual de um cliente e sugerir melhorias relacionadas com {interest}.",
          why: "Muitas pessoas pagam para perceber o que estão a fazer mal."
        },
        {
          name: "Biblioteca de Recursos de {interest}",
          desc: "Criar uma coleção paga de ferramentas, links, templates e recomendações sobre {interest}.",
          why: "Informação organizada e curada poupa tempo e tem valor."
        },
        {
          name: "Newsletter de Nicho sobre {interest}",
          desc: "Lançar uma newsletter de nicho e monetizá-la com recomendações, produtos ou acesso premium.",
          why: "Audiências por email são valiosas e mais fáceis de monetizar."
        }
      ],
      [
        {
          name: "Pacote Feito por Ti de {interest}",
          desc: "Criar uma oferta simples com preço fixo em que fazes uma tarefa específica para clientes relacionada com {interest}.",
          why: "Ofertas claras vendem melhor do que serviços vagos."
        },
        {
          name: "Micromarca nas Redes sobre {interest}",
          desc: "Construir uma pequena marca pessoal sobre {interest} para atrair clientes ou vender produtos digitais.",
          why: "Mesmo audiências pequenas podem gerar bom rendimento se houver confiança."
        },
        {
          name: "Bundle de Ferramentas de {interest}",
          desc: "Juntar templates, scripts, checklists e mini guias num único pacote pago.",
          why: "Bundles aumentam a perceção de valor e são fáceis de vender."
        },
        {
          name: "Apoio Individual em {interest}",
          desc: "Oferecer sessões diretas para ajudar pessoas que querem começar em {interest}.",
          why: "Apoio personalizado permite cobrar melhor."
        },
        {
          name: "Programa Desafio de {interest}",
          desc: "Criar um desafio de 5 ou 7 dias para ajudar pessoas a alcançar um resultado rápido em {interest}.",
          why: "Programas curtos são apelativos porque parecem alcançáveis."
        }
      ]
    ];

    function capitalizeText(text) {
      return text.charAt(0).toUpperCase() + text.slice(1);
    }

    function fillTemplate(text, interest) {
      return text.replaceAll("{interest}", interest);
    }

    function updateLanguage() {
      let language = document.getElementById("language").value;
      currentLanguage = language;

      if (language === "pt") {
        document.getElementById("title").innerText = "Gerador de Side Hustles";
        document.getElementById("subtitle").innerText = "Gera ideias de side hustle em segundos";
        document.getElementById("languageLabel").innerText = "Idioma";
        document.getElementById("interestLabel").innerText = "Competência, interesse ou nicho";
        document.getElementById("interest").placeholder = "Ex.: contabilidade, beleza, fitness, design";
        document.getElementById("generateBtn").innerText = "Gerar Side Hustles";
        document.getElementById("moreBtn").innerText = "Gerar Mais Ideias";
        document.getElementById("copyBtn").innerText = "Copiar Ideias";
        document.getElementById("footerNote").innerText = "Ferramentas inteligentes para empreendedores modernos";
      } else {
        document.getElementById("title").innerText = "Side Hustle Generator";
        document.getElementById("subtitle").innerText = "Generate side hustle ideas in seconds";
        document.getElementById("languageLabel").innerText = "Language";
        document.getElementById("interestLabel").innerText = "Skill, interest or niche";
        document.getElementById("interest").placeholder = "E.g. accounting, beauty, fitness, design";
        document.getElementById("generateBtn").innerText = "Generate Side Hustles";
        document.getElementById("moreBtn").innerText = "Generate More Ideas";
        document.getElementById("copyBtn").innerText = "Copy Ideas";
        document.getElementById("footerNote").innerText = "Smart tools for modern entrepreneurs";
      }
    }

    function renderIdeas() {
      const language = currentLanguage;
      const rawInterest = currentInterest.trim();
      const capitalizedInterest = capitalizeText(rawInterest);

      const selectedSet =
        language === "pt"
          ? ideaSetsPt[currentSetIndex % ideaSetsPt.length]
          : ideaSetsEn[currentSetIndex % ideaSetsEn.length];

      let html = "";

      if (language === "pt") {
        html += "<div class='result-title'>Ideias geradas para: <b>" + capitalizedInterest + "</b></div>";
      } else {
        html += "<div class='result-title'>Ideas generated for: <b>" + capitalizedInterest + "</b></div>";
      }

      selectedSet.forEach(function (idea, index) {
        html += "<div class='idea'>";
        html += "<span class='idea-name'><b>" + (index + 1) + ". " + fillTemplate(idea.name, capitalizedInterest) + "</b></span>";
        html += "<span class='idea-desc'>" + fillTemplate(idea.desc, rawInterest) + "</span>";
        html += "<span class='idea-why'>" + fillTemplate(idea.why, rawInterest) + "</span>";
        html += "</div>";
      });

      document.getElementById("result").innerHTML = html;
      document.getElementById("result").style.display = "block";
      document.getElementById("copyBtn").style.display = "inline-block";
      document.getElementById("moreBtn").style.display = "inline-block";
    }

    function generateIdeas() {
      const interest = document.getElementById("interest").value.trim();
      const language = document.getElementById("language").value;

      if (interest === "") {
        if (language === "pt") {
          alert("Introduz uma competência, interesse ou nicho.");
        } else {
          alert("Please enter a skill, interest or niche.");
        }
        return;
      }

      currentInterest = interest;
      currentLanguage = language;
      currentSetIndex = 0;

      renderIdeas();
    }

    function generateMoreIdeas() {
      if (!currentInterest.trim()) {
        if (currentLanguage === "pt") {
          alert("Gera primeiro as ideias iniciais.");
        } else {
          alert("Generate the first ideas before asking for more.");
        }
        return;
      }

      currentSetIndex++;
      renderIdeas();
    }

    function copyIdeas() {
      let resultText = document.getElementById("result").innerText;
      let language = document.getElementById("language").value;

      if (!resultText.trim()) {
        if (language === "pt") {
          alert("Ainda não há ideias para copiar.");
        } else {
          alert("There are no ideas to copy yet.");
        }
        return;
      }

      navigator.clipboard.writeText(resultText).then(function () {
        if (language === "pt") {
          alert("Ideias copiadas!");
        } else {
          alert("Ideas copied!");
        }
      });
    }

    updateLanguage();
  </script>
</body>
</html>
